---
import latest from '@data/latest.json'

import '@htl-stp/core/theme.css'

import '@styles/style.css';

const entries = Object.entries(latest);
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    <link rel="stylesheet" href="src/style.css">

    <title>Ifnode, but better!</title>
</head>
<body>

<h1 class="text-center heading-xl mt-lg mb-md">Ifnode, <span class="text-but-better">but better!</span> ™</h1>

<section class="section container">
    <div id="list" class="flex-column mb-lg">
        {entries.map(([key, value]) => (
                <a href={`${key.replace(/\.md$/, '')}/${value.replace(/\.md$/, '')}`}>
                    {key}
                </a>
        ))}
    </div>
</section>


</body>
</html>
