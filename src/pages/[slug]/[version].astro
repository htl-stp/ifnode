---
import '@htl-stp/core/core.css'
import '@htl-stp/core/utilities.css'
import '@htl-stp/core/components.css'
import '@styles/markdown.css'
import 'highlight.js/styles/github-dark.css';

import index from '@data/index.json'
import {marked} from "marked";
import hljs from "highlight.js";
const entries = Object.entries(index) as [string, string[]][];

function fixImagePaths(md: string) {
    return md.replace(/!\[(.*?)]\((.*?)\)/g, (_, alt, src) => {
        const newSrc = `/${src}`;
        return `![${alt}](${newSrc})`;
    });
}


interface Params {
    slug: string;
    version: string;
}

export function getStaticPaths() {
    const entries = Object.entries(index) as [string, string[]][];

    return entries.flatMap(([slug, versions]) =>
        versions.map((version) => ({
            params: { slug, version },
        }))
    );
}

const { slug } = Astro.params;
const { version } = Astro.params;

const versions = entries.find(([key]) => key === slug)?.[1].map(v => v.split('.')[0].split('T')[0]) ?? [];

const files = import.meta.glob('@data/history/**/*.md', {
    query: '?raw',
    import: 'default'
})

const path = `/data/history/${slug}/${version}`

const file = files[path];
const text: string = (await file()) as string;

const fixed = fixImagePaths(text);

const renderer = new marked.Renderer();
renderer.code = ({text, lang, escaped}) => {
    const validLang = lang && hljs.getLanguage(lang);

    const highlighted = validLang
        ? hljs.highlight(text, { language: lang }).value
        : hljs.highlightAuto(text).value;

    return `<pre><code class="hljs ${lang ?? ""}">${highlighted}</code></pre>`;
};

const parsed = await marked.parse(fixed, {renderer});
---
<h1 id="title" class="text-center heading-lg mt-lg">{slug}</h1>
<nav class="container">
    <label for="versions">Version:</label>
    <select id="versions">
        { versions.map(version => (
            <option value={version}>{version}</option>
        ))}
    </select>
</nav>

<section class="markdown-body section container mb-lg">
    <div id="content" set:html={parsed}></div>
</section>